{
  "name": "clodedrive",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "npm run test:unit && npm run test:integration",
    "test:unit": "dotenv -e .env.test -- vitest run tests/unit",
    "test:integration": "dotenv -e .env.test -- vitest run --config vitest.integration.config.js tests/integration",    "test:watch": "dotenv -e .env.test -- vitest",
    "test:db:up": "docker compose -f docker-compose.test.yml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yml down",
    "test:db:migrate": "dotenv -e .env.test -- npx prisma migrate deploy"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/lib-storage": "^3.1077.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@prisma/client": "^6.19.3",
    "busboy": "^1.6.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "file-type": "^22.0.1",
    "jsonwebtoken": "^9.0.3",
    "jwks-rsa": "^4.0.1",
    "uuid": "^14.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "nodemon": "^3.1.14",
    "prisma": "^6.19.3",
    "vitest": "^4.1.10"
  }
}
